{
  "name": "danni-bg",
  "version": "0.1.0",
  "description": "Synced local mirror of data.egov.bg with curation and machine-readable index.",
  "type": "module",
  "private": true,
  "bin": {
    "danni": "./bin/danni"
  },
  "scripts": {
    "danni": "bun run src/cli/danni.ts",
    "db:migrate": "bun run src/store/migrate-cli.ts",
    "explorer:api": "bun run --hot apps/explorer-api/src/server.ts",
    "explorer:gen-geo": "bun run packages/geo-boundaries/scripts/generate-crosswalk.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run typecheck"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.6.0"
  }
}
