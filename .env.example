# Copy to .env (gitignored; Bun auto-loads it for `bun run`).

# Chat default provider for the explorer API. Without these, /api/chat returns
# "no server default provider is configured". The chat agent uses tools, so the
# endpoint MUST support tool/function calling.
#
# Examples:
#   Self-hosted vLLM (openai-compatible), started with
#   --enable-auto-tool-choice --tool-call-parser:
EXPLORER_DEFAULT_PROVIDER=openai-compatible
EXPLORER_DEFAULT_MODEL=gemma-4-26b-uncensored
EXPLORER_DEFAULT_BASE_URL=http://spark:8000/v1
EXPLORER_DEFAULT_API_KEY=EMPTY
#
#   Anthropic:
# EXPLORER_DEFAULT_PROVIDER=anthropic
# EXPLORER_DEFAULT_MODEL=claude-sonnet-4-6
# EXPLORER_DEFAULT_API_KEY=sk-ant-...
#
# NOTE (spec 019): EXPLORER_DEFAULT_* is now a SEED. On first run the explorer API
# copies it into the platform_settings store; after that the admin settings UI is
# authoritative for the chat's default provider.

# --- Ory identity stack (spec 019; see infra/ory + docker-compose.yml) ---
# Kratos public/admin endpoints (used by the backend + the Vite dev proxy).
KRATOS_PUBLIC_URL=http://localhost:14433
KRATOS_ADMIN_URL=http://localhost:14434
# Oathkeeper access proxy fronting the gated /api/{chat,admin,auth} routes.
OATHKEEPER_PROXY_URL=http://localhost:14455
# Optional: comma-separated emails auto-promoted to admin on first login
# (otherwise use `danni admin-grant <email>`). Document the trade-off before using.
# ADMIN_BOOTSTRAP_EMAILS=you@example.com
