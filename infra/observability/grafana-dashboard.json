{
  "__comment": "danni overview dashboard (spec 032, FR-151). Import into Grafana with a Prometheus datasource. RED by route + domain signals (LLM cost/tokens, chat outcomes, 429s, active generations, index freshness). Per-tenant/key cost views attach once api_usage/token_usage are exported as labelled series.",
  "title": "danni — overview",
  "uid": "danni-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["danni", "spec-032"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate by route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(danni_http_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "5xx error ratio by route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(danni_http_requests_total{status=\"5xx\"}[5m])) / clamp_min(sum by (route) (rate(danni_http_requests_total[5m])), 1)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM spend rate (USD/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(danni_llm_cost_usd_total[15m])", "legendFormat": "USD/s" }]
    },
    {
      "id": 4,
      "title": "LLM tokens by kind",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(danni_llm_tokens_total[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Chat outcomes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(danni_chat_outcomes_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Rate-limit / quota 429s",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum by (route) (rate(danni_rate_limit_rejections_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active generations / index stale",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        { "expr": "danni_active_generations", "legendFormat": "active gens" },
        { "expr": "danni_index_stale", "legendFormat": "index stale" }
      ]
    }
  ]
}
