#!/bin/bash
# k3s agent (worker) bootstrap (spec 031). Joins the control plane over the private network.
set -euo pipefail
curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION="${k3s_version}" K3S_URL="https://${server_private_ip}:6443" K3S_TOKEN="${k3s_token}" sh -s - agent \
  --node-ip "${private_ip}" \
  --flannel-iface ens10
