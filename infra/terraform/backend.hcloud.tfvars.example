# Terraform remote-state backend config for Hetzner Object Storage (spec 031, FR-141).
# Copy to backend.hcloud.tfvars (gitignored) and run:  terraform init -backend-config=backend.hcloud.tfvars
# Then uncomment the `backend "s3"` block in versions.tf.
#
# Create the bucket + S3 credentials in the Hetzner Console (Object Storage). The endpoint is shown per
# location — copy it EXACTLY. Hetzner has no DynamoDB, so locking uses the S3-native lockfile.

bucket = "danni-tfstate"
key    = "danni/terraform.tfstate"
region = "eu-central-1" # placeholder; ignored by Hetzner (skip flags handle validation)

endpoints = { s3 = "https://nbg1.your-objectstorage.com" }

# Prefer env vars for the keys (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) over putting them here.
# access_key = "<s3-access-key>"
# secret_key = "<s3-secret-key>"

use_path_style              = true
skip_credentials_validation = true
skip_region_validation      = true
skip_requesting_account_id  = true
use_lockfile                = true
