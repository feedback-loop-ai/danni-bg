# Agentic eval config — every value is optional and falls back to the repo-root
# .env (EXPLORER_DEFAULT_*). Copy to eval/agentic/.env only to OVERRIDE.

# The running chat API to grade (system-under-test).
# EVAL_API_BASE_URL=http://localhost:8790

# SUBJECT — the model the chat runs under (defaults to EXPLORER_DEFAULT_*).
# EVAL_SUBJECT_KIND=openai-compatible
# EVAL_SUBJECT_MODEL=gemma-4-26b-uncensored
# EVAL_SUBJECT_BASE_URL=http://spark:8000/v1
# EVAL_SUBJECT_API_KEY=EMPTY

# JUDGE — the LLM-as-judge for G-Eval (defaults to EXPLORER_DEFAULT_*, i.e. gemma
# grades gemma). Repoint to a different/stronger model for judge independence.
# EVAL_JUDGE_MODEL=gemma-4-26b-uncensored
# EVAL_JUDGE_BASE_URL=http://spark:8000/v1
# EVAL_JUDGE_API_KEY=EMPTY
# EVAL_JUDGE_TEMPERATURE=0
# EVAL_JUDGE_STRUCTURED=1    # response_format=json_schema for reliable judge JSON; 0 = json_object only
# EVAL_REQUEST_TIMEOUT_S=180
