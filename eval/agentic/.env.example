# Agentic eval config — every value is optional and falls back to the repo-root
# .env (EXPLORER_DEFAULT_*). Copy to eval/agentic/.env only to OVERRIDE.

# The running chat API to grade (system-under-test).
# EVAL_API_BASE_URL=http://localhost:8790

# SUBJECT — the model the chat runs under (defaults to EXPLORER_DEFAULT_*).
# EVAL_SUBJECT_KIND=openai-compatible
# EVAL_SUBJECT_MODEL=gemma-4-26b-uncensored
# EVAL_SUBJECT_BASE_URL=http://spark:8000/v1
# EVAL_SUBJECT_API_KEY=EMPTY

# JUDGE — the LLM-as-judge for G-Eval (defaults to EXPLORER_DEFAULT_*, i.e. gemma
# grades gemma). The local gemma-26b is an UNRELIABLE judge on long enumerations
# (it false-flags grounded datasets as "fabricated"); use a frontier judge for any
# verdict you trust. The deterministic guards in guards.py cover the core fabrication
# modes without a judge at all.
# EVAL_JUDGE_MODEL=gemma-4-26b-uncensored
# EVAL_JUDGE_BASE_URL=http://spark:8000/v1
# EVAL_JUDGE_API_KEY=EMPTY
# EVAL_JUDGE_TEMPERATURE=0
# EVAL_JUDGE_STRUCTURED=1    # response_format=json_schema for reliable judge JSON; 0 = json_object only
# EVAL_REQUEST_TIMEOUT_S=180

# --- Frontier judge: Alibaba Model Studio (Qwen) ----------------------------------
# Qwen via DashScope is OpenAI-compatible, so the existing judge works unchanged —
# just point it here (the json_schema -> json_object fallback handles Qwen). Choose the
# base_url for your Model Studio region; pin a qwen-plus snapshot from the console for
# reproducibility (qwen-plus is the rolling stable alias).
# EVAL_JUDGE_KIND=openai-compatible
# EVAL_JUDGE_MODEL=qwen-plus
# EVAL_JUDGE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1   # Singapore (intl)
# # EVAL_JUDGE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1   # US (Virginia)
# # EVAL_JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1      # China (Beijing)
# EVAL_JUDGE_API_KEY=<your Model Studio API key>
